																"Debug": 1,
																"UsecaseSelector": [
																	{
																		"Type": "Tag",
																		"Parameter": ["vcf.parameter", "seamlessMode", "0"],
																		"Condition": ["int", "==3"/* rear main */],
																		"Result": "ROIREMOSAICVIDEO1610",
																		"Debug": 1
																	}
																]
															}
