							"Type": "EISMode",
							"Condition": ["int", "==0", "==1", "==9", "==14", "==16", "==12", "==4", "==18"],
							"Result": "VIDEO",
							"UsecaseSelector": [
								{ // 60FPS
									"Type": "FrameRate",
									"Condition": ["int", "==60", "==50"],
									"Result": "VIDEO16960",
									"UsecaseSelector": [
										{//广角摄像头
											"Type": "Camera ID",
											"Condition": ["int", "==2"],
											"Result": "4K60"
										},
										{ // 4K30fps
											"Type": "Width",
											"Condition": ["int", "==3840"],
											"UsecaseSelector": [
												{
													"Type": "Height",
													"Condition": ["int", "==2160"],
