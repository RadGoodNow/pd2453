<?xml version="1.0" encoding="utf-8"?>
<config version="1.0">

    <!-- Face Config -->
    <face-config
        support-3d="False"
        support-pay="False"
        support-assistant="False"
        support-convenience="False"
        set-convenience="False"
        set_wallpaper_brightness_adjust="True"
        set_privacy_brightness_adjust="True"
        support-vivo-supplier="False"
        forbid-release="False"
        support-camera-boost="False"
        support-secure-camera="False"
        support-trace="False"
        multi-faceNum="2"
    />

    <!-- Camera Skip Frame -->
    <skip-frame value="3"/>

    <!-- Adjust Brightness -->
    <adjust-brightness color="0xFFFDFA" start-brightness="0.0" brightness="0.1297665" duration="1200"/>

    <!-- Payment package list -->
    <payment-package package="com.tencent.mm"/>
    <payment-package package="com.eg.android.AlipayGphone"/>
    <payment-package package="com.tencent.mobileqq"/>
    <payment-package package="com.taobao.taobao"/>
    <payment-package package="com.tmall.wireless"/>
    <payment-package package="com.taobao.idlefish"/>
    <payment-package package="com.taobao.movie.android"/>
    <payment-package package="com.taobao.trip"/>
    <payment-package package="com.taobao.litetao"/>
    <payment-package package="com.citic21.user"/>

    <!-- Platform performace list -->
    <platform-performance resources="0x40800000, 0xfff, 0x40804000, 0xfff, 0x40800100, 0xfff, 0x40804100, 0xfff,0x40800200, 0x852, 0x40804200, 0x9FC"/>

</config>