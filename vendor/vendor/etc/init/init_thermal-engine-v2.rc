#! /bin/sh
#
#Copyright (c) 2021 Qualcomm Technologies, Inc.
#All Rights Reserved.
#Confidential and Proprietary - Qualcomm Technologies, Inc.

service thermal-engine /vendor/bin/thermal-engine-v2
	class main
	user root
	group root system
	socket thermal-send-client stream 0666 system system
	socket thermal-recv-client stream 0660 system system
	socket thermal-recv-passive-client stream 0666 system system
	socket thermal-send-rule stream 0660 system system
	capabilities DAC_OVERRIDE

on property:sys.boot_completed=1
	mkdir /dev/thermal/
	mkdir /dev/thermal/cpu0/
	mkdir /dev/thermal/cpu1/
	mkdir /dev/thermal/cpu2/
	mkdir /dev/thermal/cpu3/
	mkdir /dev/thermal/cpu4/
	mkdir /dev/thermal/cpu5/
	mkdir /dev/thermal/cpu6/
	mkdir /dev/thermal/cpu7/

	mkdir /dev/thermal/cpu0/topology
	mkdir /dev/thermal/cpu1/topology
	mkdir /dev/thermal/cpu2/topology
	mkdir /dev/thermal/cpu3/topology
	mkdir /dev/thermal/cpu4/topology
	mkdir /dev/thermal/cpu5/topology
	mkdir /dev/thermal/cpu6/topology
	mkdir /dev/thermal/cpu7/topology

	mkdir /dev/thermal/cpu0/cpufreq
	mkdir /dev/thermal/cpu1/cpufreq
	mkdir /dev/thermal/cpu2/cpufreq
	mkdir /dev/thermal/cpu3/cpufreq
	mkdir /dev/thermal/cpu4/cpufreq
	mkdir /dev/thermal/cpu5/cpufreq
	mkdir /dev/thermal/cpu6/cpufreq
	mkdir /dev/thermal/cpu7/cpufreq

	copy /sys/devices/system/cpu/cpu0/topology/cluster_id /dev/thermal/cpu0/topology/cluster_id
	copy /sys/devices/system/cpu/cpu1/topology/cluster_id /dev/thermal/cpu1/topology/cluster_id
	copy /sys/devices/system/cpu/cpu2/topology/cluster_id /dev/thermal/cpu2/topology/cluster_id
	copy /sys/devices/system/cpu/cpu3/topology/cluster_id /dev/thermal/cpu3/topology/cluster_id
	copy /sys/devices/system/cpu/cpu4/topology/cluster_id /dev/thermal/cpu4/topology/cluster_id
	copy /sys/devices/system/cpu/cpu5/topology/cluster_id /dev/thermal/cpu5/topology/cluster_id
	copy /sys/devices/system/cpu/cpu6/topology/cluster_id /dev/thermal/cpu6/topology/cluster_id
	copy /sys/devices/system/cpu/cpu7/topology/cluster_id /dev/thermal/cpu7/topology/cluster_id

	copy /sys/devices/system/cpu/cpu0/topology/physical_package_id /dev/thermal/cpu0/topology/physical_package_id
	copy /sys/devices/system/cpu/cpu1/topology/physical_package_id /dev/thermal/cpu1/topology/physical_package_id
	copy /sys/devices/system/cpu/cpu2/topology/physical_package_id /dev/thermal/cpu2/topology/physical_package_id
	copy /sys/devices/system/cpu/cpu3/topology/physical_package_id /dev/thermal/cpu3/topology/physical_package_id
	copy /sys/devices/system/cpu/cpu4/topology/physical_package_id /dev/thermal/cpu4/topology/physical_package_id
	copy /sys/devices/system/cpu/cpu5/topology/physical_package_id /dev/thermal/cpu5/topology/physical_package_id
	copy /sys/devices/system/cpu/cpu6/topology/physical_package_id /dev/thermal/cpu6/topology/physical_package_id
	copy /sys/devices/system/cpu/cpu7/topology/physical_package_id /dev/thermal/cpu7/topology/physical_package_id

	copy /sys/devices/system/cpu/cpu0/cpufreq/cpuinfo_max_freq /dev/thermal/cpu0/cpufreq/cpuinfo_max_freq
	copy /sys/devices/system/cpu/cpu1/cpufreq/cpuinfo_max_freq /dev/thermal/cpu1/cpufreq/cpuinfo_max_freq
	copy /sys/devices/system/cpu/cpu2/cpufreq/cpuinfo_max_freq /dev/thermal/cpu2/cpufreq/cpuinfo_max_freq
	copy /sys/devices/system/cpu/cpu3/cpufreq/cpuinfo_max_freq /dev/thermal/cpu3/cpufreq/cpuinfo_max_freq
	copy /sys/devices/system/cpu/cpu4/cpufreq/cpuinfo_max_freq /dev/thermal/cpu4/cpufreq/cpuinfo_max_freq
	copy /sys/devices/system/cpu/cpu5/cpufreq/cpuinfo_max_freq /dev/thermal/cpu5/cpufreq/cpuinfo_max_freq
	copy /sys/devices/system/cpu/cpu6/cpufreq/cpuinfo_max_freq /dev/thermal/cpu6/cpufreq/cpuinfo_max_freq
	copy /sys/devices/system/cpu/cpu7/cpufreq/cpuinfo_max_freq /dev/thermal/cpu7/cpufreq/cpuinfo_max_freq

	copy /sys/devices/system/cpu/cpu0/cpufreq/scaling_available_frequencies /dev/thermal/cpu0/cpufreq/scaling_available_frequencies
	copy /sys/devices/system/cpu/cpu1/cpufreq/scaling_available_frequencies /dev/thermal/cpu1/cpufreq/scaling_available_frequencies
	copy /sys/devices/system/cpu/cpu2/cpufreq/scaling_available_frequencies /dev/thermal/cpu2/cpufreq/scaling_available_frequencies
	copy /sys/devices/system/cpu/cpu3/cpufreq/scaling_available_frequencies /dev/thermal/cpu3/cpufreq/scaling_available_frequencies
	copy /sys/devices/system/cpu/cpu4/cpufreq/scaling_available_frequencies /dev/thermal/cpu4/cpufreq/scaling_available_frequencies
	copy /sys/devices/system/cpu/cpu5/cpufreq/scaling_available_frequencies /dev/thermal/cpu5/cpufreq/scaling_available_frequencies
	copy /sys/devices/system/cpu/cpu6/cpufreq/scaling_available_frequencies /dev/thermal/cpu6/cpufreq/scaling_available_frequencies
	copy /sys/devices/system/cpu/cpu7/cpufreq/scaling_available_frequencies /dev/thermal/cpu7/cpufreq/scaling_available_frequencies

	copy /sys/devices/system/cpu/cpu0/cpufreq/scaling_boost_frequencies /dev/thermal/cpu0/cpufreq/scaling_boost_frequencies
	copy /sys/devices/system/cpu/cpu1/cpufreq/scaling_boost_frequencies /dev/thermal/cpu1/cpufreq/scaling_boost_frequencies
	copy /sys/devices/system/cpu/cpu2/cpufreq/scaling_boost_frequencies /dev/thermal/cpu2/cpufreq/scaling_boost_frequencies
	copy /sys/devices/system/cpu/cpu3/cpufreq/scaling_boost_frequencies /dev/thermal/cpu3/cpufreq/scaling_boost_frequencies
	copy /sys/devices/system/cpu/cpu4/cpufreq/scaling_boost_frequencies /dev/thermal/cpu4/cpufreq/scaling_boost_frequencies
	copy /sys/devices/system/cpu/cpu5/cpufreq/scaling_boost_frequencies /dev/thermal/cpu5/cpufreq/scaling_boost_frequencies
	copy /sys/devices/system/cpu/cpu6/cpufreq/scaling_boost_frequencies /dev/thermal/cpu6/cpufreq/scaling_boost_frequencies
	copy /sys/devices/system/cpu/cpu7/cpufreq/scaling_boost_frequencies /dev/thermal/cpu7/cpufreq/scaling_boost_frequencies
	restart thermal-engine
