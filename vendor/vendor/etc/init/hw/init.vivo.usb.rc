on zygote-start
    setprop sys.usb.vcar.mode 0
    setprop sys.usb.car.mtp 7
    setprop sys.usb.vidVendor 0x2d95
    setprop sys.usb.vidProduct 0x6012
    mkdir /config/usb_gadget/g1/functions/mass_storage.1 0770 system usb
    write /config/usb_gadget/g1/functions/mass_storage.1/lun.0/cdrom 1
    write /config/usb_gadget/g1/functions/mass_storage.1/lun.0/file "/system/etc/autorun.iso"
    mkdir /config/usb_gadget/g1/functions/gser.nmea.0 0770 system usb
    mkdir /config/usb_gadget/g1/functions/hid.0 0770 system usb
    write /config/usb_gadget/g1/functions/gsi.rndis/rndis_class_id 1
    mkdir /config/usb_gadget/g1/functions/acm.0 0770 system usb
    write /sys/module/usbcore/parameters/autosuspend 6
    chmod 0666 /sys/devices/virtual/usb_eye_tune/usb/repeater_phytune
    write /sys/module/block/parameters/events_dfl_poll_msecs 1000
    chmod 0666 /sys/devices/virtual/usb30_eye_tune/usb30/ss_phytune
    trigger usb_mod_node_per

on usb_mod_node_per
    wait /sys/devices/platform/soc/soc:qcom,pmic_glink/soc:qcom,pmic_glink:qcom,ucsi/set_ccom
    write /dev/kmsg "chmod 0666 to set_ccom"
    chmod 0666 /sys/devices/platform/soc/soc:qcom,pmic_glink/soc:qcom,pmic_glink:qcom,ucsi/set_ccom

on property:sys.usb.config=charging && property:sys.usb.configfs=1 && property:ro.vendor.vivo.support.cdrom=0 && property:sys.usb.vcar.mode=0
    write /config/usb_gadget/g1/idVendor 0x2d95
    write /config/usb_gadget/g1/idProduct 0x6002

on property:sys.usb.config=charging && property:sys.usb.configfs=1 && property:ro.vendor.vivo.support.cdrom=1 && property:sys.usb.vcar.mode=0
    write /config/usb_gadget/g1/idVendor 0x2d95
    write /config/usb_gadget/g1/idProduct 0x6012

on property:sys.usb.config=charging,adb && property:sys.usb.configfs=1 && property:ro.vendor.vivo.support.cdrom=0 && property:sys.usb.vcar.mode=0
    write /config/usb_gadget/g1/idVendor 0x2d95
    write /config/usb_gadget/g1/idProduct 0x6003

on property:sys.usb.config=charging,adb && property:sys.usb.configfs=1 && property:ro.vendor.vivo.support.cdrom=1 && property:sys.usb.vcar.mode=0
    write /config/usb_gadget/g1/idVendor 0x2d95
    write /config/usb_gadget/g1/idProduct 0x6013

on property:sys.usb.config=charging,vusbd && property:sys.usb.configfs=1
    write /config/usb_gadget/g1/idVendor 0x2d95
    write /config/usb_gadget/g1/idProduct 0x6003

on property:sys.usb.config=mtp && property:sys.usb.configfs=1 && property:ro.vendor.vivo.support.cdrom=0 && property:sys.usb.vcar.mode=0
    write /config/usb_gadget/g1/idVendor 0x2d95
    write /config/usb_gadget/g1/idProduct 0x6002

on property:sys.usb.config=mtp && property:sys.usb.configfs=1 && property:ro.vendor.vivo.support.cdrom=1 && property:sys.usb.vcar.mode=0
    write /config/usb_gadget/g1/idVendor 0x2d95
    write /config/usb_gadget/g1/idProduct 0x6012

on property:sys.usb.config=mtp,adb && property:sys.usb.configfs=1 && property:ro.vendor.vivo.support.cdrom=0 && property:sys.usb.vcar.mode=0
    write /config/usb_gadget/g1/idVendor 0x2d95
    write /config/usb_gadget/g1/idProduct 0x6003

on property:sys.usb.config=mtp,adb && property:sys.usb.configfs=1 && property:ro.vendor.vivo.support.cdrom=1 && property:sys.usb.vcar.mode=0
    write /config/usb_gadget/g1/idVendor 0x2d95
    write /config/usb_gadget/g1/idProduct 0x6013

on property:sys.usb.config=ptp && property:sys.usb.configfs=1 && property:ro.vendor.vivo.support.cdrom=0 && property:sys.usb.vcar.mode=0
    write /config/usb_gadget/g1/idVendor 0x2d95
    write /config/usb_gadget/g1/idProduct 0x6004

on property:sys.usb.config=ptp && property:sys.usb.configfs=1 && property:ro.vendor.vivo.support.cdrom=1 && property:sys.usb.vcar.mode=0
    write /config/usb_gadget/g1/idVendor 0x2d95
    write /config/usb_gadget/g1/idProduct 0x6014

on property:sys.usb.config=ptp,adb && property:sys.usb.configfs=1 && property:ro.vendor.vivo.support.cdrom=0 && property:sys.usb.vcar.mode=0
    write /config/usb_gadget/g1/idVendor 0x2d95
    write /config/usb_gadget/g1/idProduct 0x6005

on property:sys.usb.config=ptp,adb && property:sys.usb.configfs=1 && property:ro.vendor.vivo.support.cdrom=1 && property:sys.usb.vcar.mode=0
    write /config/usb_gadget/g1/idVendor 0x2d95
    write /config/usb_gadget/g1/idProduct 0x6015

on property:sys.usb.config=car,mtp && property:sys.usb.configfs=1 && property:sys.usb.vcar.mode=0
    write /config/usb_gadget/g1/idVendor 0x2d95
    write /config/usb_gadget/g1/idProduct 0x6012

on property:sys.usb.config=car,vusbd && property:sys.usb.configfs=1 && property:sys.usb.vcar.mode=0
    write /config/usb_gadget/g1/idVendor ${sys.usb.vidVendor}
    write /config/usb_gadget/g1/idProduct ${sys.usb.vidProduct}

on property:sys.usb.config=rndis,none && property:sys.usb.configfs=1
    write /config/usb_gadget/g1/idVendor 0x2d95
    write /config/usb_gadget/g1/idProduct 0x600a

on property:sys.usb.config=rndis,none,adb && property:sys.usb.configfs=1
    write /config/usb_gadget/g1/idVendor 0x2d95
    write /config/usb_gadget/g1/idProduct 0x600b

on property:sys.usb.config=mass_storage && property:sys.usb.configfs=1
    write /config/usb_gadget/g1/idVendor 0x2d95
    write /config/usb_gadget/g1/idProduct 0x6008

on property:sys.usb.config=mass_storage,adb && property:sys.usb.configfs=1
    write /config/usb_gadget/g1/idVendor 0x2d95
    write /config/usb_gadget/g1/idProduct 0x6009

on property:vendor.switch.vusbd=debugport
    setprop sys.usb.config none
    setprop sys.usb.config diag,serial_cdev,serial_tty,rmnet_ipa,mass_storage,adb

on property:vendor.switch.vusbd=debugport_5g
    setprop sys.usb.config none
    setprop sys.usb.config diag,diag_mdm,serial_cdev,serial_cdev_mdm,nmea,rmnet,mass_storage,adb

on property:vendor.switch.vusbd=vusbd
    setprop sys.usb.config none
    setprop sys.usb.config vusbd

on property:vendor.switch.vusbd=car_vusbd
    setprop sys.usb.config none
    setprop sys.usb.config car,vusbd

on property:init.svc.vusbd=stopped
    setprop sys.usb.ffs.ready 0

on property:persist.vivo.cts.adb.enable=yes && property:sys.usb.configfs=1 && property:ro.build.type=eng
    write /dev/kmsg "persist.vivo.cts.adb.enable=yes&ro.build.type=eng&clear persist.vendor.usb.config value"
    setprop persist.vendor.usb.config ""
    setprop sys.usb.config none
    setprop sys.usb.config vusbd

on property:sys.usb.vserialno=*
    write /dev/kmsg "connect bmw_car, sys.usb.vserialno:"${sys.usb.vserialno}
    write /config/usb_gadget/g1/idVendor 0x2d95
    write /config/usb_gadget/g1/idProduct 0x7000
    write /config/usb_gadget/g1/strings/0x409/serialnumber ${sys.usb.vserialno}
    write /config/usb_gadget/g2/strings/0x409/serialnumber ${sys.usb.vserialno}
    setprop sys.usb.vserialno.state ${sys.usb.vserialno}

on property:sys.usb.config=* && property:sys.usb.configfs=1
    write dev/kmsg "qcom_rc cfg_link "${sys.usb.config}

on property:sys.usb.config=none && property:sys.usb.configfs=1
    write dev/kmsg "qcom_rc cfg_link sys.usb.config=none"
    stop vusbd
    rm /config/usb_gadget/g1/configs/b.1/f1
    rm /config/usb_gadget/g1/configs/b.1/f2
    rm /config/usb_gadget/g1/configs/b.1/f3
    rm /config/usb_gadget/g1/configs/b.1/f4
    rm /config/usb_gadget/g1/configs/b.1/f5
    rm /config/usb_gadget/g1/configs/b.1/f6
    rm /config/usb_gadget/g1/configs/b.1/f7
    rm /config/usb_gadget/g1/configs/b.1/f8
    rm /config/usb_gadget/g1/configs/b.1/f9

on property:sys.usb.config=car,mtp && property:vendor.usb.use_ffs_mtp=1 && property:sys.usb.configfs=1
    write /config/usb_gadget/g1/configs/b.1/strings/0x409/configuration "car-ffs-mtp"
    rm /config/usb_gadget/g1/configs/b.1/f1
    rm /config/usb_gadget/g1/configs/b.1/f2
    rm /config/usb_gadget/g1/configs/b.1/f3
    rm /config/usb_gadget/g1/configs/b.1/f4
    rm /config/usb_gadget/g1/configs/b.1/f5
    rm /config/usb_gadget/g1/configs/b.1/f6
    rm /config/usb_gadget/g1/configs/b.1/f7
    rm /config/usb_gadget/g1/configs/b.1/f8
    rm /config/usb_gadget/g1/configs/b.1/f9
    symlink /config/usb_gadget/g1/configs/b.1 /config/usb_gadget/g1/os_desc/b.1
    symlink /config/usb_gadget/g1/functions/ffs.mtp /config/usb_gadget/g1/configs/b.1/f1
    write /config/usb_gadget/g1/UDC ${sys.usb.controller}
    setprop sys.usb.state ${sys.usb.config}

on property:sys.usb.config=car,mtp && property:vendor.usb.use_ffs_mtp=0 && property:sys.usb.configfs=1
    write /config/usb_gadget/g1/configs/b.1/strings/0x409/configuration "car-mtp"
    rm /config/usb_gadget/g1/configs/b.1/f1
    rm /config/usb_gadget/g1/configs/b.1/f2
    rm /config/usb_gadget/g1/configs/b.1/f3
    rm /config/usb_gadget/g1/configs/b.1/f4
    rm /config/usb_gadget/g1/configs/b.1/f5
    rm /config/usb_gadget/g1/configs/b.1/f6
    rm /config/usb_gadget/g1/configs/b.1/f7
    rm /config/usb_gadget/g1/configs/b.1/f8
    rm /config/usb_gadget/g1/configs/b.1/f9
    symlink /config/usb_gadget/g1/configs/b.1 /config/usb_gadget/g1/os_desc/b.1
    symlink /config/usb_gadget/g1/functions/mtp.gs0 /config/usb_gadget/g1/configs/b.1/f1
    write /config/usb_gadget/g1/UDC ${sys.usb.controller}
    setprop sys.usb.state ${sys.usb.config}

on property:sys.usb.config=car,vusbd && property:sys.usb.configfs=1
    start vusbd

on property:sys.usb.ffs.ready=1 && property:sys.usb.config=car,vusbd && property:vendor.usb.use_ffs_mtp=0 && property:sys.usb.configfs=1
    write /config/usb_gadget/g1/configs/b.1/strings/0x409/configuration "car_vusbd"
    rm /config/usb_gadget/g1/configs/b.1/f1
    rm /config/usb_gadget/g1/configs/b.1/f2
    rm /config/usb_gadget/g1/configs/b.1/f3
    rm /config/usb_gadget/g1/configs/b.1/f4
    rm /config/usb_gadget/g1/configs/b.1/f5
    rm /config/usb_gadget/g1/configs/b.1/f6
    rm /config/usb_gadget/g1/configs/b.1/f7
    rm /config/usb_gadget/g1/configs/b.1/f8
    rm /config/usb_gadget/g1/configs/b.1/f9
    symlink /config/usb_gadget/g1/configs/b.1 /config/usb_gadget/g1/os_desc/b.1
    symlink /config/usb_gadget/g1/functions/mtp.gs0 /config/usb_gadget/g1/configs/b.1/f1
    symlink /config/usb_gadget/g1/functions/ffs.adb /config/usb_gadget/g1/configs/b.1/f2
    write /config/usb_gadget/g1/UDC ${sys.usb.controller}
    setprop sys.usb.state ${sys.usb.config}
    write /dev/kmsg "enter car_vusbd mode sys.usb.vidVendor:"${sys.usb.vidVendor}
    write /dev/kmsg "enter car_vusbd mode sys.usb.vidProduct:"${sys.usb.vidProduct}

on property:sys.usb.ffs.ready=1 && property:sys.usb.config=car,vusbd && property:vendor.usb.use_ffs_mtp=1 && property:sys.usb.configfs=1
    write /config/usb_gadget/g1/configs/b.1/strings/0x409/configuration "car_vusbd"
    rm /config/usb_gadget/g1/configs/b.1/f1
    rm /config/usb_gadget/g1/configs/b.1/f2
    rm /config/usb_gadget/g1/configs/b.1/f3
    rm /config/usb_gadget/g1/configs/b.1/f4
    rm /config/usb_gadget/g1/configs/b.1/f5
    rm /config/usb_gadget/g1/configs/b.1/f6
    rm /config/usb_gadget/g1/configs/b.1/f7
    rm /config/usb_gadget/g1/configs/b.1/f8
    rm /config/usb_gadget/g1/configs/b.1/f9
    symlink /config/usb_gadget/g1/configs/b.1 /config/usb_gadget/g1/os_desc/b.1
    symlink /config/usb_gadget/g1/functions/ffs.mtp /config/usb_gadget/g1/configs/b.1/f1
    symlink /config/usb_gadget/g1/functions/ffs.adb /config/usb_gadget/g1/configs/b.1/f2
    write /config/usb_gadget/g1/UDC ${sys.usb.controller}
    setprop sys.usb.state ${sys.usb.config}
    write /dev/kmsg "enter car_vusbd mode sys.usb.vidVendor:"${sys.usb.vidVendor}
    write /dev/kmsg "enter car_vusbd mode sys.usb.vidProduct:"${sys.usb.vidProduct}

on property:sys.usb.config=vusbd && property:sys.usb.configfs=1
    start vusbd

on property:sys.usb.ffs.ready=1 && property:sys.usb.config=vusbd && property:sys.usb.configfs=1
    write /config/usb_gadget/g1/configs/b.1/strings/0x409/configuration "vusbd"
    rm /config/usb_gadget/g1/configs/b.1/f1
    rm /config/usb_gadget/g1/configs/b.1/f2
    rm /config/usb_gadget/g1/configs/b.1/f3
    rm /config/usb_gadget/g1/configs/b.1/f4
    rm /config/usb_gadget/g1/configs/b.1/f5
    rm /config/usb_gadget/g1/configs/b.1/f6
    rm /config/usb_gadget/g1/configs/b.1/f7
    rm /config/usb_gadget/g1/configs/b.1/f8
    rm /config/usb_gadget/g1/configs/b.1/f9
    symlink /config/usb_gadget/g1/configs/b.1 /config/usb_gadget/g1/os_desc/b.1
    write /config/usb_gadget/g1/idVendor 0x2d95
    write /config/usb_gadget/g1/idProduct 0x6001
    symlink /config/usb_gadget/g1/functions/ffs.adb /config/usb_gadget/g1/configs/b.1/f1
    write /config/usb_gadget/g1/UDC ${sys.usb.controller}
    setprop sys.usb.state ${sys.usb.config}

on property:sys.usb.config=charging,vusbd && property:sys.usb.configfs=1
    start vusbd

on property:sys.usb.ffs.ready=1 && property:sys.usb.config=charging,vusbd && property:sys.usb.configfs=1
    write /config/usb_gadget/g1/configs/b.1/strings/0x409/configuration "vusbd"
    rm /config/usb_gadget/g1/configs/b.1/f1
    rm /config/usb_gadget/g1/configs/b.1/f2
    rm /config/usb_gadget/g1/configs/b.1/f3
    rm /config/usb_gadget/g1/configs/b.1/f4
    rm /config/usb_gadget/g1/configs/b.1/f5
    rm /config/usb_gadget/g1/configs/b.1/f6
    rm /config/usb_gadget/g1/configs/b.1/f7
    rm /config/usb_gadget/g1/configs/b.1/f8
    rm /config/usb_gadget/g1/configs/b.1/f9
    symlink /config/usb_gadget/g1/configs/b.1 /config/usb_gadget/g1/os_desc/b.1
    symlink /config/usb_gadget/g1/functions/ffs.adb /config/usb_gadget/g1/configs/b.1/f1
    write /config/usb_gadget/g1/UDC ${sys.usb.controller}
    setprop sys.usb.state ${sys.usb.config}

on property:sys.usb.config=mtp,vusbd && property:sys.usb.configfs=1
    start vusbd

on property:sys.usb.ffs.ready=1 && property:sys.usb.config=mtp,vusbd && property:vendor.usb.use_ffs_mtp=0 && property:sys.usb.configfs=1
    write /config/usb_gadget/g1/configs/b.1/strings/0x409/configuration "mtp_vusbd"
    rm /config/usb_gadget/g1/configs/b.1/f1
    rm /config/usb_gadget/g1/configs/b.1/f2
    rm /config/usb_gadget/g1/configs/b.1/f3
    rm /config/usb_gadget/g1/configs/b.1/f4
    rm /config/usb_gadget/g1/configs/b.1/f5
    rm /config/usb_gadget/g1/configs/b.1/f6
    rm /config/usb_gadget/g1/configs/b.1/f7
    rm /config/usb_gadget/g1/configs/b.1/f8
    rm /config/usb_gadget/g1/configs/b.1/f9
    symlink /config/usb_gadget/g1/configs/b.1 /config/usb_gadget/g1/os_desc/b.1
    write /config/usb_gadget/g1/idVendor 0x2d95
    write /config/usb_gadget/g1/idProduct 0x6003
    symlink /config/usb_gadget/g1/functions/mtp.gs0 /config/usb_gadget/g1/configs/b.1/f1
    symlink /config/usb_gadget/g1/functions/ffs.adb /config/usb_gadget/g1/configs/b.1/f2
    write /config/usb_gadget/g1/UDC ${sys.usb.controller}
    setprop sys.usb.state ${sys.usb.config}

on property:sys.usb.ffs.ready=1 && property:sys.usb.config=mtp,vusbd && property:vendor.usb.use_ffs_mtp=1 && property:sys.usb.configfs=1
    write /config/usb_gadget/g1/configs/b.1/strings/0x409/configuration "ffs-mtp_vusbd"
    rm /config/usb_gadget/g1/configs/b.1/f1
    rm /config/usb_gadget/g1/configs/b.1/f2
    rm /config/usb_gadget/g1/configs/b.1/f3
    rm /config/usb_gadget/g1/configs/b.1/f4
    rm /config/usb_gadget/g1/configs/b.1/f5
    rm /config/usb_gadget/g1/configs/b.1/f6
    rm /config/usb_gadget/g1/configs/b.1/f7
    rm /config/usb_gadget/g1/configs/b.1/f8
    rm /config/usb_gadget/g1/configs/b.1/f9
    symlink /config/usb_gadget/g1/configs/b.1 /config/usb_gadget/g1/os_desc/b.1
    write /config/usb_gadget/g1/idVendor 0x2d95
    write /config/usb_gadget/g1/idProduct 0x6003
    symlink /config/usb_gadget/g1/functions/ffs.mtp /config/usb_gadget/g1/configs/b.1/f1
    symlink /config/usb_gadget/g1/functions/ffs.adb /config/usb_gadget/g1/configs/b.1/f2
    write /config/usb_gadget/g1/UDC ${sys.usb.controller}
    setprop sys.usb.state ${sys.usb.config}

on property:sys.usb.config=ptp,vusbd && property:sys.usb.configfs=1
    start vusbd

on property:sys.usb.ffs.ready=1 && property:sys.usb.config=ptp,vusbd && property:vendor.usb.use_ffs_mtp=0 && property:sys.usb.configfs=1
    write /config/usb_gadget/g1/configs/b.1/strings/0x409/configuration "ptp_vusbd"
    rm /config/usb_gadget/g1/configs/b.1/f1
    rm /config/usb_gadget/g1/configs/b.1/f2
    rm /config/usb_gadget/g1/configs/b.1/f3
    rm /config/usb_gadget/g1/configs/b.1/f4
    rm /config/usb_gadget/g1/configs/b.1/f5
    rm /config/usb_gadget/g1/configs/b.1/f6
    rm /config/usb_gadget/g1/configs/b.1/f7
    rm /config/usb_gadget/g1/configs/b.1/f8
    rm /config/usb_gadget/g1/configs/b.1/f9
    symlink /config/usb_gadget/g1/configs/b.1 /config/usb_gadget/g1/os_desc/b.1
    write /config/usb_gadget/g1/idVendor 0x2d95
    write /config/usb_gadget/g1/idProduct 0x6005
    symlink /config/usb_gadget/g1/functions/ptp.gs1 /config/usb_gadget/g1/configs/b.1/f1
    symlink /config/usb_gadget/g1/functions/ffs.adb /config/usb_gadget/g1/configs/b.1/f2
    write /config/usb_gadget/g1/UDC ${sys.usb.controller}
    setprop sys.usb.state ${sys.usb.config}

on property:sys.usb.ffs.ready=1 && property:sys.usb.config=ptp,vusbd && property:vendor.usb.use_ffs_mtp=1 && property:sys.usb.configfs=1
    write /config/usb_gadget/g1/configs/b.1/strings/0x409/configuration "ffs-ptp_vusbd"
    rm /config/usb_gadget/g1/configs/b.1/f1
    rm /config/usb_gadget/g1/configs/b.1/f2
    rm /config/usb_gadget/g1/configs/b.1/f3
    rm /config/usb_gadget/g1/configs/b.1/f4
    rm /config/usb_gadget/g1/configs/b.1/f5
    rm /config/usb_gadget/g1/configs/b.1/f6
    rm /config/usb_gadget/g1/configs/b.1/f7
