
on late-fs
    chmod 0666 /dev/vivo_haptic
    chown system system /dev/vivo_haptic
    chmod 0666 /dev/vivo_haptic_vice
    chown system system /dev/vivo_haptic_vice

    chmod 0666 /sys/kernel/hold_actuator/hold_status
    chown system system /sys/kernel/hold_actuator/hold_status

    chmod 0666 /dev/vivo_haptic_core
    chown system system /dev/vivo_haptic_core

    chown system system /dev/aac_richtap_dev

    chmod 0666 /sys/class/leds/vibrator/reg
    chown system system /sys/class/leds/vibrator/reg

    chmod 0666 /sys/kernel/hold_actuator/hold_status
    chmod 0666 /sys/kernel/hold_actuator/hold_status1
    chmod 0666 /sys/kernel/hold_actuator/hold_status2
    chmod 0666 /sys/kernel/hold_actuator/hold_status3
    chmod 0666 /sys/kernel/hold_actuator/hold_status4
    chmod 0666 /sys/kernel/hold_actuator/hold_status5
    chmod 0666 /sys/kernel/hold_actuator_rear_wide/hold_status
    chmod 0666 /sys/kernel/hold_actuator_rear_tele/hold_status
    chmod 0666 /sys/kernel/ois0_ctrl/hold_status
    chmod 0666 /sys/kernel/ois1_ctrl/hold_status
    chmod 0666 /sys/kernel/ois2_ctrl/hold_status
    chmod 0666 /sys/kernel/ois3_ctrl/hold_status
    chmod 0666 /sys/kernel/ois4_ctrl/hold_status
    chown system system /sys/kernel/hold_actuator/hold_status
    chown system system /sys/kernel/hold_actuator/hold_status1
    chown system system /sys/kernel/hold_actuator/hold_status2
    chown system system /sys/kernel/hold_actuator/hold_status3
    chown system system /sys/kernel/hold_actuator/hold_status4
    chown system system /sys/kernel/hold_actuator/hold_status5
    chown system system /sys/kernel/hold_actuator_rear_wide/hold_status
    chown system system /sys/kernel/hold_actuator_rear_tele/hold_status
    chown system system /sys/kernel/ois0_ctrl/hold_status
    chown system system /sys/kernel/ois1_ctrl/hold_status
    chown system system /sys/kernel/ois2_ctrl/hold_status
    chown system system /sys/kernel/ois3_ctrl/hold_status
    chown system system /sys/kernel/ois4_ctrl/hold_status

service vendor.vibrator-default /vendor/bin/hw/vendor.vivo.hardware.vibrator.custom.service
    class hal
    user system
    group system

    setenv RICHTAP_DEVICE_PATH  /dev/vivo_haptic;/dev/vivo_haptic_vice
    setenv ENV_RICHTAP_CONFIG_PATH /odm/etc/aac_richtap.config;/odm/etc/aac_richtap_1.config

on property:sys.boot_completed=1
    chmod 0666 /dev/vivo_haptic_core
    chown system system /dev/vivo_haptic_core
    chmod 0666 /dev/vivo_haptic
    chown system system /dev/vivo_haptic
    chmod 0666 /dev/vivo_haptic_vice
    chown system system /dev/vivo_haptic_vice
    setprop vendor.haptic.calibrate.done 1
