    <BaseConfig>
        <!-- 0: front gtr skin, 1: front gtr HD, 2: front lowlight HD, 3: back gtr skin, 4: back gtr HD, 5: back super group photo HD -->
        <AlgoMode>3</AlgoMode>
        <!-- max number of faces can be processed -->
        <MaxFaceNum>5</MaxFaceNum>
        <!-- enable drcGain or not -->
        <UseDrcgain>0</UseDrcgain>
        <!-- border rate for blending HD result with input -->
        <BlendRate>10</BlendRate>
        <!-- algorithm run condition -->
        <GlobalRunCondition use="1">
            <!-- lumType: 0 means ISO, 1 means LuxIndex -->
            <LumVal type="0" min="0" max="51200"></LumVal>
            <!-- roll: [minRoll,maxRoll], yaw: [minYaw, maxYaw], pitch: [minPitch, maxPitch] -->
            <FaceAngle minRoll="0" maxRoll="360" minYaw="-90" maxYaw="90" minPitch="-90" maxPitch="90"></FaceAngle>
        </GlobalRunCondition>
        <DetailConfig>
            <A>6.6162771e-7</A>
            <B>-0.6937669</B>
            <MinC>0.25</MinC>
            <OrganMaxV>256</OrganMaxV>
            <SkinRate>0.7</SkinRate>
            <FiveOrganRate>1.0</FiveOrganRate>
        </DetailConfig>
        <!-- method: 0 - USM, 1 - Pyramid-->
        <SharpenConfig method="0">
            <USM>
                <Sigma>1.0</Sigma>
                <Weight>1.0</Weight>
                <Threshold>1</Threshold>
            </USM>
            <Pyramid>
                <!-- maximum levelMum is 4 -->
                <LevelNum>3</LevelNum>
                <Levels>16 64 256</Levels>
            </Pyramid>
        </SharpenConfig>
        <!-- FaceBoxConfig: method 0 - use 103 landmark, 1 - use 127 landmark, 2 - only use face box -->
        <FaceBoxConfig method="0">
            <!-- face box expand rate. -->
            <ExpandRateL>0.20</ExpandRateL>
            <ExpandRateT>0.65</ExpandRateT>
            <ExpandRateR>0.20</ExpandRateR>
            <ExpandRateB>0.35</ExpandRateB>
        </FaceBoxConfig>
    </BaseConfig>

