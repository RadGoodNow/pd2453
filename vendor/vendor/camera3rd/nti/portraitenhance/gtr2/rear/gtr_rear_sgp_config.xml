<?xml version="1.0" encoding="utf-8"?>
<GTRConfig version="2.0.10.0">
<!-- MT6991 -->
    <BaseConfig>
        <!-- 0: front gtr skin, 1: front gtr HD, 2: front lowlight HD, 3: back gtr skin, 4: back gtr HD, 5: back super group photo HD -->
        <AlgoMode>5</AlgoMode>
        <!-- max number of faces can be processed -->
        <MaxFaceNum>60</MaxFaceNum>
        <!-- enable drcGain or not -->
        <UseDrcgain>0</UseDrcgain>
        <!-- border rate for blending HD result with input -->
        <BlendRate>10</BlendRate>
        <!-- algorithm run condition -->
        <GlobalRunCondition use="1">
            <!-- lumType: 0 means ISO, 1 means LuxIndex -->
            <LumVal type="0" min="0" max="25600"></LumVal>
            <!-- roll: [minRoll,maxRoll], yaw: [minYaw, maxYaw], pitch: [minPitch, maxPitch] -->
            <FaceAngle minRoll="0" maxRoll="360" minYaw="-65" maxYaw="65" minPitch="-80" maxPitch="80"></FaceAngle>
        </GlobalRunCondition>
        <DetailConfig>
            <A>6.6162771e-7</A>
            <B>-0.6937669</B>
            <MinC>0.25</MinC>
            <OrganMaxV>256</OrganMaxV>
            <SkinRate>1.0</SkinRate>
            <FiveOrganRate>1.0</FiveOrganRate>
        </DetailConfig>
        <!-- method: 0 - USM, 1 - Pyramid-->
        <SharpenConfig method="0">
            <USM>
                <Sigma>1.0</Sigma>
                <Weight>1.0</Weight>
                <Threshold>1</Threshold>
            </USM>
            <Pyramid>
                <!-- maximum levelMum is 4 -->
                <LevelNum>3</LevelNum>
                <Levels>16 64 256</Levels>
            </Pyramid>
        </SharpenConfig>
        <!-- FaceBoxConfig: method 0 - use 103 landmark, 1 - use 127 landmark, 2 - only use face box -->
        <FaceBoxConfig method="2">
            <!-- face box expand rate. -->
            <ExpandRateL>0.25</ExpandRateL>
            <ExpandRateT>0.30</ExpandRateT>
            <ExpandRateR>0.25</ExpandRateR>
            <ExpandRateB>0.20</ExpandRateB>
        </FaceBoxConfig>
    </BaseConfig>

    <!-- model config list -->
    <ModelConfigList>
        <!-- for small face, low zoom, cover all lum range. -->
        <ModelConfig use="1" nid="0" engine="6" device="0" power="0" thread="1" space2depth="0" resi="1" range="0">
            <ModelPath>gtr_sgp10_sm8750_00.vdnn</ModelPath>
            <InputNode>input_0_0</InputNode>
            <OutputNode>conv2d_34_f_0</OutputNode>
        </ModelConfig>
        <!-- for middle face, low zoom, cover all lum range. -->
        <ModelConfig use="1" nid="1" engine="6" device="0" power="0" thread="1" space2depth="0" resi="1" range="0">
            <ModelPath>gtr_sgp10_sm8750_00.vdnn</ModelPath>
            <InputNode>input_0_0</InputNode>
            <OutputNode>conv2d_34_f_0</OutputNode>
        </ModelConfig>
        <!-- for big face, low zoom, cover all lum range. -->
        <ModelConfig use="1" nid="2" engine="6" device="0" power="0" thread="1" space2depth="0" resi="1" range="0">
            <ModelPath>gtr_sgp10_sm8750_02.vdnn</ModelPath>
            <InputNode>input_0_0</InputNode>
            <OutputNode>conv2d_36_f_0</OutputNode>
        </ModelConfig>
    </ModelConfigList>

    <!-- effect config list, segment according to UIZoomRatio and lum (ISO or LuxIndex). -->
    <EffectConfigList lumType="0">
        <!-- uiZoomRatio: [minUIZoomRatio, maxUIZoomRatio), lum: [minLum, maxLum) -->
        <EffectConfig minUIZoomRatio="0.1" maxUIZoomRatio="100.1" minLum="0" maxLum="25600">
            <!-- local algorithm run condition -->
            <LocalRunCondition use="1">
                <!-- min Laplacian Clarity Threshold, won't run algorithm if the laplacian clarity of face region lower than this config value. -->
                <MinLaplacian>1.0 1.0 1.0</MinLaplacian>
            </LocalRunCondition>
            <!-- model selector base on face size: the long border length of face box. if only one face received, use SingalFaceThreshold as MinFace size for bigModel. -->
            <ModelSelector useSingalFaceThreshold="0" SingalFaceThreshold="796">
                <MinFace use="1" minFace="10"  maxFace="90"   minConfidence="0.1" nid="0"></MinFace>
                <MidFace use="1" minFace="90"  maxFace="900"  minConfidence="0.1" nid="1"></MidFace>
                <MaxFace use="1" minFace="900" maxFace="6000" minConfidence="0.0" nid="2"></MaxFace>
            </ModelSelector>
            <!-- fusion weights with netout of Input -->
            <HDFusionWeight useHighlightThreshold="1" highlightThreshold="256">
                <!-- corresponding to the regions: hair|eye|brow|mouth|skin|bodyWithoutFace|background -->
                <MinFace use="1">1.00 1.00 1.00 1.00 1.00 1.00 0.00</MinFace>
                <MidFace use="1">1.00 1.00 1.00 1.00 1.00 1.00 0.00</MidFace>
                <MaxFace use="1">1.00 1.00 1.00 1.00 1.00 1.00 0.00</MaxFace>
            </HDFusionWeight>
            <!-- fusion weights with sharpen of Input -->
            <SharpenFusionWeight useHighlightThreshold="1" highlightThreshold="256">
                <!-- corresponding to the regions: hair|eye|brow|mouth|skin|bodyWithoutFace|background -->
                <MinFace use="0">0.60 0.80 0.80 0.80 0.50 0.30 0.10</MinFace>
                <MidFace use="0">0.60 0.80 0.80 0.80 0.50 0.30 0.10</MidFace>
                <MaxFace use="0">0.60 0.80 0.80 0.80 0.50 0.30 0.10</MaxFace>
            </SharpenFusionWeight>
            <!-- hd post process method: 0 without detail, 1 with detail -->
            <HDPostMethod>
                <MinFace>0</MinFace>
                <MidFace>0</MidFace>
                <MaxFace>0</MaxFace>
            </HDPostMethod>
        </EffectConfig>
    </EffectConfigList>
</GTRConfig>
