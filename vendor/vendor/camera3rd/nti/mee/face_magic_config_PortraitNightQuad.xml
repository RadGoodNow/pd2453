                <MidISOMaxFaceSharpMaskWeight>0.6 0.8 0.8 0.8 0.2 0.2 0</MidISOMaxFaceSharpMaskWeight>
                <HighISOMinFaceSharpMaskWeight>0.6 0.8 0.8 0.8 0.5 0.5 0</HighISOMinFaceSharpMaskWeight>
                <HighISOMidFaceSharpMaskWeight>0.6 0.8 0.8 0.8 0.5 0.5 0</HighISOMidFaceSharpMaskWeight>
                <HighISOMaxFaceSharpMaskWeight>0.6 0.8 0.8 0.8 0.2 0.5 0</HighISOMaxFaceSharpMaskWeight>
            </MaskWeight>
            <FaceBoxConfig>
                <BlendRate>20</BlendRate>
                <ExtendRateX>11</ExtendRateX>
                <ExtendRateY>35</ExtendRateY>
                <FaceIouThred>0.1</FaceIouThred>
                <UpOffset>0.2</UpOffset>
            </FaceBoxConfig>
            <FaceQualityConfig>
                <!-- 小于LaplacianThred 会选择lowQualityModel. -->
                <LaplacianThred>10 10</LaplacianThred>
                <!-- 大于LuxIndexThred，会选择MidQualityModel ,否则是HighQuality -->
                <LuxIndexThred>240</LuxIndexThred>
                <LowQualityBlurKSize>3</LowQualityBlurKSize>
            </FaceQualityConfig>
            <ModelInfos>
                <MinModelLowQuality use="1" engine="7" device="0" power="0" netsize="512" index="6">
