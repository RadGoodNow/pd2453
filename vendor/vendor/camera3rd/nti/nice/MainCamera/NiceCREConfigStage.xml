    <DitherParamHDR use='0' UseInCVtone='0' description="HDR Enable dither: use=1, use dither only in MTKTone: UseInCVtone=0">
        <!-- in the case of use=1, dither will take effect if any of the three conditions DrcgainThd or LuxIndexThd or ISOThd are met-->
        <DrcgainThd>0</DrcgainThd>
        <LuxIndexThd>0</LuxIndexThd>
        <ISOThd>0</ISOThd>
        <!-- if dither takes effect, the number of arguments for DrcgainValue and DitherLevel should be equal. The last value of the DrcgainValue array must be 4-->
        <!-- if <DrcgainValue>2, 3, 4</DrcgainValue>, it means that the drcgain is divided into three segments: 1-2, 2-3, 3-4. The maximum value of DitherLevel is 65535-->
        <DrcgainValue>1.5, 2.5, 3, 4</DrcgainValue>
        <DitherLevel>1.0, 2.5, 3.0, 8.0</DitherLevel>
    </DitherParamHDR>
    <DitherParam use='0' UseInCVtone='0' description="Normal Enable dither: use=1, use dither only in MTKTone: UseInCVtone=0">
        <!-- in the case of use=1, dither will take effect if any of the three conditions DrcgainThd or LuxIndexThd or ISOThd are met-->
        <DrcgainThd>0</DrcgainThd>
        <LuxIndexThd>0</LuxIndexThd>
        <ISOThd>0</ISOThd>
        <!-- if dither takes effect, the number of arguments for DrcgainValue and DitherLevel should be equal. The last value of the DrcgainValue array must be 4-->
        <!-- if <DrcgainValue>2, 3, 4</DrcgainValue>, it means that the drcgain is divided into three segments: 1-2, 2-3, 3-4. The maximum value of DitherLevel is 65535-->
        <DrcgainValue>1.5, 2.5, 3, 4</DrcgainValue>
        <DitherLevel>1.0, 2.5, 3.0, 8.0</DitherLevel>
    </DitherParam>
