    <group __id__="virtual_temp_define">
        <elem __name__="virtual_shell_ntc"
            select_first_enable="virtual_shell;ntc"/>

        <elem __name__="virtual_battery"
            select_first_enable="battery;ps_battery"/>
    </group>

    <group __id__="virtual_temp_config">
        <elem __name__="temp_hbm_enter"
            virtual_temp="virtual_shell_ntc"
            virtual_shell="40"
            ntc="41"/>

        <elem __name__="temp_hbm_quit"
            virtual_temp="virtual_shell_ntc"
            virtual_shell="37"
