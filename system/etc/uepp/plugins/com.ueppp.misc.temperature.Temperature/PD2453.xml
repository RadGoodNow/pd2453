        temp_scale_size="43"
        temp_recover_size="41"
        temp_switch_to_4g="50"
        temp_switch_to_5g="47"
        temp_broadcast_camera_trigger_start="38"
        temp_broadcast_camera_trigger_end="66"
        temp_to_packmode_freeze="46"
        temp_to_packmode_unfreeze="42"
        temp_to_packmode_enter="40"
        temp_car_mode_start="48"
        temp_check_ccc_enter="46"
        temp_check_ccc_exit="44"
