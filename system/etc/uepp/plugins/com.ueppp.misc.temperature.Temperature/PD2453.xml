        <elem __name__="temp_htp_nav_shell_ntc"
            virtual_temp="virtual_shell_ntc"
            virtual_shell="50"
            ntc="55"/>

        <elem __name__="temp_htp_enter_shell_ntc"
            virtual_temp="virtual_shell_ntc"
            virtual_shell="53"
            ntc="58"/>
    </group>

    <group __id__="country_region__V__IN">
        <group __id__="virtual_temp_config">
            <elem __name__="temp_htp_enter_shell_ntc"
                virtual_temp="virtual_shell_ntc"
                virtual_shell="53"
                ntc="65"/>
        </group>
    </group>

    <group __id__="country_region__V__EU">
        <group __id__="virtual_temp_config">
            <elem __name__="temp_htp_enter_shell_ntc"
                virtual_temp="virtual_shell_ntc"
